{
  "name": "ag-chat-backup",
  "displayName": "ag-chat-backup",
  "description": "Backs up Antigravity chat logs.",
  "publisher": "makyrugant",
  "license": "MIT",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ag-chat-backup.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "ag-chat-backup.showManager",
        "title": "AG: Open Conversation Manager"
      }
    ],
    "configuration": {
      "title": "Antigravity Chat Backup",
      "properties": {
        "agChatBackup.fullInitialBackup": {
          "type": "boolean",
          "default": null,
          "description": "Whether to perform a full initial backup of all existing Antigravity logs on startup. Set to null to prompt on first run."
        },
        "agChatBackup.backupPath": {
          "type": "string",
          "default": "",
          "description": "Custom path for storing backups. If empty, defaults to Desktop/AG_Chat_Backups."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
